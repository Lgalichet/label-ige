generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

enum ResponseValue {
  humain
  partage
  ia
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  username  String   @unique
  role      UserRole @default(user)

  // Profil public
  firstName String?
  lastName  String?
  avatarUrl String?
  company   String?
  jobTitle  String?
  bio       String?
  website   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  pages    Page[]
  posts    Post[]

  @@map("users")
}

model Project {
  id             String   @id @default(cuid())
  userId         String
  creationNumber String   @unique
  title          String
  creatorName    String
  creationDate   DateTime
  creatorUrl     String?
  projectUrl     String?
  description    String?
  toolsUsed      String?
  score          Float    @default(0)
  isPublic       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentTypes ContentType[]

  @@map("projects")
}

model ContentType {
  id        String @id @default(cuid())
  projectId String
  type      String // texte | image | video | audio
  weight    Float  @default(25) // pondération du type dans le score global (%)
  score     Float  @default(0)

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses Response[]

  @@map("content_types")
}

model Response {
  id            String        @id @default(cuid())
  contentTypeId String
  questionId    String
  response      ResponseValue
  weighting     Int // snapshot de la pondération au moment de la réponse

  contentType ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id])

  @@unique([contentTypeId, questionId])
  @@map("responses")
}

model Question {
  id          String  @id @default(cuid())
  contentType String // texte | image | video | audio
  question    String
  weighting   Int // en %
  active      Boolean @default(true)
  sortOrder   Int     @default(0)

  responses Response[]

  @@map("questions")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

// ====================================================================
// CMS — Pages statiques administrables (type WordPress)
// ====================================================================

model Page {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         String   // markdown
  excerpt         String?
  metaTitle       String?
  metaDescription String?
  published       Boolean  @default(false)
  publishedAt     DateTime?
  authorId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([published])
  @@map("pages")
}

// ====================================================================
// Blog
// ====================================================================

model Post {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String?
  content         String   // markdown
  coverImage      String?
  metaTitle       String?
  metaDescription String?
  published       Boolean  @default(false)
  publishedAt     DateTime?
  authorId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author     User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categories Category[] @relation("PostCategories")

  @@index([published, publishedAt])
  @@map("posts")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  posts Post[] @relation("PostCategories")

  @@map("categories")
}

# ============================================================
# Label IGE — Variables d'environnement
# Copier ce fichier en .env.local et renseigner les valeurs
# NE JAMAIS committer .env.local
# ============================================================

# --- Clerk (Auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/connexion
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/inscription
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/espace-createur
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/espace-createur

# --- Base de données (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Resend (Emails) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Sentry (Monitoring) ---
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# --- Umami (Analytics) ---
NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
UMAMI_URL=https://umami-exko.vercel.app

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
